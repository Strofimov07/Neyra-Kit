{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "NEYRA_HOOK_HOST=codex \"$(git rev-parse --show-toplevel)/agents/neyra-dev-kit/hooks/session-start.sh\"",
            "statusMessage": "Loading Neyra kit rules"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "NEYRA_HOOK_HOST=codex \"$(git rev-parse --show-toplevel)/agents/neyra-dev-kit/hooks/pre-tool-use-guard.sh\"",
            "statusMessage": "Checking Neyra kit guard"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "NEYRA_HOOK_HOST=codex \"$(git rev-parse --show-toplevel)/agents/neyra-dev-kit/hooks/post-tool-use-format.sh\"",
            "statusMessage": "Formatting edited file"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "NEYRA_HOOK_HOST=codex \"$(git rev-parse --show-toplevel)/agents/neyra-dev-kit/hooks/stop-gate.sh\"",
            "timeout": 30,
            "statusMessage": "Running Neyra kit doctor"
          }
        ]
      }
    ]
  }
}
