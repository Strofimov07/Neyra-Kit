{
  "mcpServers": {
    "neyra": {
      "command": "node",
      "args": ["{{NEYRA_MCP_ENTRY}}"],
      "env": {
        "NEYRA_API_URL": "${NEYRA_API_URL}",
        "NEYRA_API_KEY": "${NEYRA_API_KEY}",
        "NEYRA_IOS_DEVICE_ID": "${NEYRA_IOS_DEVICE_ID}",
        "NEYRA_APP_ID": "${NEYRA_APP_ID}",
        "NEYRA_ASO_URL": "${NEYRA_ASO_URL}",
        "NEYRA_ASO_TOKEN": "${NEYRA_ASO_TOKEN}"
      }
    }
  }
}
